COMPOSE_PROJECT_NAME=vekolom
COMPOSE_PATH_SEPARATOR=';'
COMPOSE_FILE='docker-compose.yml;docker-compose.prod.yml'

APP_DEBUG=True

APP_SECRET_KEY=
APP_HOST=0.0.0.0
APP_PORT=8001
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_TITLE="Vekolom Admin"

# -----------------------------------------------------------------------------
# Флаги сборки production-бандлов (только для prod-режима).
# Не влияют на Vite — Vite собирается отдельно через `npm run build`.
# -----------------------------------------------------------------------------
APP_BUNDLE_LEGACY_JS=true
APP_BUNDLE_CUSTOM_CSS=true

# --- SEO ---
SEO_SITE_URL=https://example.ru
SEO_OG_IMAGE_PATH=images/common/logo.png

POSTGRES_HOST=postgresdb-vekolom
POSTGRES_POST=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

POSTGRES_POOL_SIZE=5
POSTGRES_POOL_OVERFLOW_SIZE=10
POSTGRES_AUTOFLUSH=false
POSTGRES_EXPIRE_ON_COMMIT=false
POSTGRES_MAINTENANCE_DB=postgres

GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30

UV_PROJECT_ENVIRONMENT=/opt/venv

MEDIA_MEDIA_ROOT=./media
MEDIA_MEDIA_URL=/media/

STATIC_ROOT=static
STATIC_URL=/static/

ADMIN_TINYMCE_ASSETS_DIR=static/vendor/tinymce
ADMIN_TINYMCE_ASSETS_URL=/assets/tinymce
ADMIN_TINYMCE_TINYMCE_JS_PATH=tinymce.min.js
ADMIN_TINYMCE_TINYMCE_JQUERY_JS_PATH=jquery/tinymce-jquery.min.js
ADMIN_TINYMCE_HEIGHT=600
ADMIN_TINYMCE_MENUBAR=true
ADMIN_TINYMCE_STATUSBAR=true
ADMIN_TINYMCE_TOOLBAR="undo redo | bold italic underline | bullist numlist | link image table | code fullscreen"
ADMIN_TINYMCE_PLUGINS="lists link image table code fullscreen wordcount quickbars"
ADMIN_TINYMCE_CONTENT_STYLE=
ADMIN_TINYMCE_EXTRA_OPTIONS_JSON={"license_key":"gpl"}

# -----------------------------------------------------------------------------
# Vite frontend assets
# -----------------------------------------------------------------------------
# false -> legacy static links in templates
# true  -> Vite dev server in DEBUG / Vite manifest in production
VITE_ENABLED=true
VITE_DEV_SERVER_ORIGIN=http://localhost:5173
VITE_FRONTEND_ROOT=frontend
VITE_BUILD_DIR=static/dist
VITE_MANIFEST_FILE=manifest.json
VITE_ASSET_URL_PREFIX=/static/dist

# -----------------------------------------------------------------------------
# Legacy assets (classic JS: jQuery, плагины, старые скрипты)
# -----------------------------------------------------------------------------
# Путь до JSON-манифеста бандлов. Может лежать где угодно.
LEGACY_MANIFEST_PATH=static/legacy_scripts.json

# -----------------------------------------------------------------------------
# Custom CSS (пользовательские стили, не обрабатываемые Vite)
# -----------------------------------------------------------------------------
# Путь до JSON-манифеста CSS-модулей. Может лежать где угодно.
CUSTOM_CSS_MANIFEST_PATH=static/custom_css.json

BACKUP_ENABLED=false
BACKUP_INCLUDE_DIRS=["media","static"]
BACKUP_IGNORE_FILE=.backupignore
BACKUP_EXCLUDE_PATTERNS=[]
BACKUP_TEMP_DIR=tmp/backups
BACKUP_FILENAME_PREFIX=files_backup_
BACKUP_REMOTE_DIR=/vekolom/backups/files
BACKUP_RETENTION_COUNT=10
BACKUP_SCHEDULE_CRON=
BACKUP_INTERVAL_MINUTES=100
BACKUP_LOG_FILE=logs/files_backup.log
BACKUP_LOG_LEVEL=INFO
BACKUP_TIMEZONE=Europe/Moscow
BACKUP_WEBDAV_BASE_URL=https://webdav.cloud.mail.ru
BACKUP_WEBDAV_USERNAME=
BACKUP_WEBDAV_PASSWORD=
BACKUP_VERIFY_TLS=true
BACKUP_REQUEST_TIMEOUT_SECONDS=120
BACKUP_LOCK_REDIS_URL=
BACKUP_LOCK_KEY=vekolom:backup:files:lock
BACKUP_LOCK_TTL_SECONDS=7200
BACKUP_FOLLOW_SYMLINKS=false
BACKUP_WRITE_SHA256=true