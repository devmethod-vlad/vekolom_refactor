COMPOSE_PROJECT_NAME=vekolom_infra
COMPOSE_PATH_SEPARATOR=';'
COMPOSE_FILE='docker-compose.yml;docker-compose.service.nginx.yml'
TZ=Europe/Moscow
PGTZ=Europe/Moscow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# =============================================================================
# Nginx
# =============================================================================
# Окружение: dev | prod
NGINX_ENV=dev

# Порты на хосте (dev: 8080/8443, prod: 80/443)
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# Хосты, готовности которых nginx ждёт перед стартом (host:port через запятую)
NGINX_WAIT_HOSTS=vekolom:8001
NGINX_WAIT_TIMEOUT=60

# Пути к проектам
VEKOLOM_PROJECT_DIR=./src/back/vekolom